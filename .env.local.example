# =============================================
# Copy this file to .env.local and fill in values
# =============================================

# Supabase — from Supabase dashboard → Settings → API / Settings → General
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Server-only. NEVER prefix with NEXT_PUBLIC. Treat like a password.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key

# Calendly — from your event type's share URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-handle/intro-call

# Your domain
NEXT_PUBLIC_SITE_URL=https://beetelhire.in

# Optional — for encrypted social tokens (LinkedIn / Instagram tokens stored in DB)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTEGRATION_TOKEN_ENCRYPTION_KEY=replace-with-a-random-32-byte-hex-string

# Optional — admin notification email
ADMIN_NOTIFICATION_EMAIL=admin@beetelhire.in
